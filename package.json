{
  "name": "@citelens/middleware",
  "version": "0.1.3",
  "description": "Serve your CiteLens-hosted llms.txt and llms-full.txt natively in Next.js. No redirects.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "citelens-setup": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  },
  "keywords": [
    "llms.txt",
    "llms-full.txt",
    "GEO",
    "generative engine optimization",
    "AI readability",
    "AI search",
    "ChatGPT",
    "Next.js",
    "middleware",
    "citelens"
  ],
  "author": "CiteLens <shane@citelens.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shan33k/citelens-middleware"
  },
  "homepage": "https://citelens.dev",
  "bugs": {
    "url": "mailto:shane@citelens.dev"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "next": "^14.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0"
  }
}
